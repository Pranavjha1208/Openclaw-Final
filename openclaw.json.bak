{
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "fixit": {
      "enabled": true,
      "jwtSecret": "fixit-dev-jwt-secret-2026",
      "mongoUri": "",
      "mongoDatabase": "fixit_whatsapp_agent_dev",
      "allowDevJwt": true,
      "cors": {
        "allowOrigins": ["http://localhost:5173", "http://localhost:5174"]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "google/gemini-2.5-flash"
      },
      "skipBootstrap": true,
      "workspace": "./.openclaw-local/workspace"
    }
  },
  "plugins": {
    "entries": {
      "mongodb": {
        "enabled": true,
        "config": {
          "uri": "",
          "database": "fixit_whatsapp_agent_dev",
          "collection": "d_lead"
        }
      }
    }
  },
  "env": {
    "vars": {
      "GEMINI_API_KEY": ""
    }
  }
}
